              'AirPods or earbuds', 'Headphones', 'Mouse', 'Portable power bank'
            ]
          },
          {
            title: 'Cables and Support Tech',
            note: '',
            items: [
              'Car charger', 'HDMI cable', 'Extension cord', 'Travel power strip', 'Flash drive', 'Portable speaker if needed'
            ]
          }
        ]
      },
      {
        tab: 'Grooming & Laundry',
        sections: [
          {
            title: 'Toiletries and Grooming',
            note: '',
            items: [
              'Toothbrush', 'Toothpaste', 'Floss picks', 'Mouthwash', 'Deodorant', 'Body wash',
              'Shampoo', 'Conditioner', 'Razor', 'Shaving cream', 'Comb / brush', 'Nail clippers',
              'Lotion', 'Cologne', 'Beard trimmer', 'Clippers', 'Aftershave', 'Hair product',
              'Breath mints', 'Facial cleanser', 'Face moisturizer'
            ]
          },
          {
            title: 'Laundry / Clothing Care',
            note: '',
            items: [
              'Laundry bag for dirty clothes', 'Travel detergent pods', 'Dryer sheets', 'Stain remover pen', 'Lint roller', 'Compact steamer', 'Spare hangers'
            ]
          }
        ]
      },
      {
        tab: 'Quantity Model',
        sections: [
          {
            title: '7-Day Trip Quantity Guide',
            note: 'Adjust up or down based on trip length.',
            items: [
              '7 workout shirts', '5 workout shorts / joggers', '3 casual shirts', '2 polos', '2 pairs jeans / casual pants',
              '3 dress shirts', '2 full suits', '2 ties', '2 pocket squares', '10 underwear', '10 pairs socks',
              '3 pairs dress socks', '1 sleep set', '1 light jacket', '1 pair walking shoes', '1 pair training shoes', '1 pair dress shoes'
            ]
          },
          {
            title: 'Medication and Supplement Quantity Guide',
            note: '',
            items: [
              'All prescriptions for full trip plus 7 extra days', '3–4 pairs of compression socks',
              'Protein powder portions for each day plus extras', 'Enough pre-workout for each training day plus extras',
              'Enough creatine / HMB / carnitine / amino acids for each training day plus extras'
            ]
          }
        ]
      },
      {
        tab: 'Final Check',
        sections: [
          {
            title: 'Final Pre-Departure Review',
            note: 'Use this before walking out the door.',
            items: [
              'Medications packed', 'CPAP packed', 'Chargers packed', 'Dress shoes packed', 'Belts packed',
              'Ties and cufflinks packed', 'Workout gear packed', 'Compression socks packed', 'IDs and cards packed',
              'Emergency contact sheet packed', 'iPad packed', 'Laptop packed'
            ]
          },
          {
            title: 'Suit Packing Method',
            note: 'These are action steps, not just items.',
            items: [
              'Each suit placed in garment bag', 'Each suit matched with exact shirt, tie, socks, belt, and shoes',
              'Ties and pocket squares placed in separate zip pouches', 'Dress shoes stuffed with socks or shoe trees',
              'Cufflinks, tie clips, and collar stays placed in one small hard case',
              'All medicines moved to carry-on or personal bag'
            ]
          }
        ]
      }
    ];

    const tabsEl = document.getElementById('tabs');
    const panelsEl = document.getElementById('panels');
    let currentTab = 0;

    function slugify(text) {
      return text.toLowerCase().replace(/[^a-z0-9]+/g, '-');
    }

    function buildUI() {
      data.forEach((tabData, tabIndex) => {
        const btn = document.createElement('button');
        btn.className = 'tab-btn' + (tabIndex === 0 ? ' active' : '');
        btn.textContent = tabData.tab;
        btn.onclick = () => activateTab(tabIndex);
        tabsEl.appendChild(btn);

        const panel = document.createElement('div');
        panel.className = 'tab-panel' + (tabIndex === 0 ? ' active' : '');
        panel.dataset.tabIndex = tabIndex;

        tabData.sections.forEach((section, sectionIndex) => {
          const sectionDiv = document.createElement('div');
          sectionDiv.className = 'section';
          sectionDiv.innerHTML = `
            <h2>${section.title}</h2>
            ${section.note ? `<p class="note">${section.note}</p>` : ''}
            <div class="checklist"></div>
          `;
          const checklist = sectionDiv.querySelector('.checklist');

          section.items.forEach((item, itemIndex) => {
            const key = `tab${tabIndex}-sec${sectionIndex}-item${itemIndex}`;
            const checked = localStorage.getItem(key) === 'true';
            const label = document.createElement('label');
            label.className = 'item' + (checked ? ' done' : '');
            label.innerHTML = `
              <input type="radio" name="${key}" ${checked ? 'checked' : ''} data-key="${key}">
              <span>${item}</span>
            `;
            const radio = label.querySelector('input');
            radio.addEventListener('change', function() {
              localStorage.setItem(key, this.checked ? 'true' : 'false');
              label.classList.toggle('done', this.checked);
              updateSummary();
            });
            checklist.appendChild(label);
          });
          panel.appendChild(sectionDiv);
        });
        panelsEl.appendChild(panel);
      });
      updateSummary();
    }

    function activateTab(index) {
      currentTab = index;
      document.querySelectorAll('.tab-btn').forEach((btn, i) => btn.classList.toggle('active', i === index));
      document.querySelectorAll('.tab-panel').forEach((panel, i) => panel.classList.toggle('active', i === index));
    }

    function getCurrentPanelRadios() {
      return document.querySelector(`.tab-panel[data-tab-index="${currentTab}"]`).querySelectorAll('input[type="radio"]');
    }

    function markAllCurrentTab() {
      getCurrentPanelRadios().forEach(radio => {
        radio.checked = true;
        localStorage.setItem(radio.dataset.key, 'true');
        radio.closest('label').classList.add('done');
      });
      updateSummary();
    }

    function clearCurrentTab() {
      getCurrentPanelRadios().forEach(radio => {
        radio.checked = false;
        localStorage.setItem(radio.dataset.key, 'false');
        radio.closest('label').classList.remove('done');
      });
      updateSummary();
    }

    function clearAllItems() {
      document.querySelectorAll('input[type="radio"]').forEach(radio => {
        radio.checked = false;
        localStorage.setItem(radio.dataset.key, 'false');
        radio.closest('label').classList.remove('done');
      });
      updateSummary();
    }

    function updateSummary() {
      const radios = document.querySelectorAll('input[type="radio"]');
      const total = radios.length;
      const done = [...radios].filter(r => localStorage.getItem(r.dataset.key) === 'true').length;
      const remaining = total - done;
      const pct = total ? Math.round((done / total) * 100) : 0;
      document.getElementById('doneCount').textContent = done;
      document.getElementById('totalCount').textContent = total;
      document.getElementById('remainingCount').textContent = remaining;
      document.getElementById('percentCount').textContent = pct + '%';
    }

    buildUI();
  </script>
</body>
</html>
