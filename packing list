<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Packing Checklist</title>
  <style>
    :root {
      --bg: #f4f6f8;
      --panel: #ffffff;
      --line: #d7dde5;
      --text: #1f2933;
      --muted: #52606d;
      --accent: #5b4fcf;
      --accent-soft: #eceafe;
      --done: #e8f7ee;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }
    .wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
    }
    h1 {
      margin: 0 0 10px;
      font-size: 30px;
    }
    .sub {
      color: var(--muted);
      margin-bottom: 18px;
      line-height: 1.5;
    }
    .toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 18px;
    }
    button {
      border: 1px solid var(--line);
      background: white;
      padding: 10px 14px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 600;
    }
    button:hover { background: #f9fafb; }
    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
    }
    .card .num {
      font-size: 24px;
      font-weight: 700;
      color: var(--accent);
    }
    .tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }
    .tab-btn {
      background: white;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 14px;
      font-size: 14px;
    }
    .tab-btn.active {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }
    .tab-panel {
      display: none;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
    }
    .tab-panel.active { display: block; }
    .section {
      margin-bottom: 24px;
      border-top: 1px solid #eef2f6;
      padding-top: 18px;
    }
    .section:first-child {
      border-top: none;
      padding-top: 0;
    }
    h2 {
      margin: 0 0 8px;
      font-size: 22px;
    }
    h3 {
      margin: 0 0 10px;
      font-size: 18px;
      color: var(--accent);
    }
    .note {
      color: var(--muted);
      font-size: 14px;
      margin: 0 0 12px;
      line-height: 1.5;
    }
    .checklist {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 10px 16px;
    }
    label.item {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px 12px;
      background: #fff;
      cursor: pointer;
      transition: 0.15s ease;
    }
    label.item.done {
      background: var(--done);
      border-color: #9fd3b2;
    }
    .item input[type="radio"] {
      margin-top: 3px;
      transform: scale(1.15);
    }
    .item span {
      line-height: 1.35;
      font-size: 15px;
    }
    .muted { color: var(--muted); }
    .footer-note {
      margin-top: 22px;
      font-size: 14px;
      color: var(--muted);
    }
    @media print {
      body { background: white; }
      .toolbar, .tabs { display: none; }
      .tab-panel { display: block !important; page-break-inside: avoid; margin-bottom: 16px; }
      .wrap { max-width: 100%; padding: 0; }
      .card { break-inside: avoid; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>Packing Checklist</h1>
    <div class="sub">Tabbed packing checklist with radio-button checkoffs. Your progress saves in this browser on this device.</div>

    <div class="toolbar">
      <button onclick="markAllCurrentTab()">Check All Items in Current Tab</button>
      <button onclick="clearCurrentTab()">Clear Current Tab</button>
      <button onclick="clearAllItems()">Clear Entire Checklist</button>
      <button onclick="window.print()">Print / Save PDF</button>
    </div>

    <div class="summary">
      <div class="card"><div class="num" id="doneCount">0</div><div>Items Checked</div></div>
      <div class="card"><div class="num" id="totalCount">0</div><div>Total Items</div></div>
      <div class="card"><div class="num" id="remainingCount">0</div><div>Items Remaining</div></div>
      <div class="card"><div class="num" id="percentCount">0%</div><div>Completion</div></div>
    </div>

    <div class="tabs" id="tabs"></div>
    <div id="panels"></div>

    <div class="footer-note">Notes: Keep all medications, CPAP, chargers, and critical documents in carry-on or quick-access luggage. Meloxicam may increase bleeding risk with Eliquis; hydrocodone and methocarbamol may increase drowsiness. Confirm trip use with your prescriber or pharmacist.</div>
  </div>

  <script>
    const data = [
      {
        tab: 'Documents & Essentials',
